# ============================================
# MedDash 医院运营数据看板 - 配置文件
# ============================================

# 阿里云百炼 DashScope API Key
# 
# 如何获取:
# 1. 访问: https://dashscope.console.aliyun.com/
# 2. 或访问: https://bailian.console.aliyun.com/
# 3. 注册/登录阿里云账号
# 4. 在控制台创建 API-KEY
# 5. 将生成的 Key 粘贴到下方
#
# 注意:
# - 请妥善保管您的 API Key，不要提交到公开的代码仓库
# - 首次使用有免费额度，具体以阿里云官方为准
# - 推荐使用 qwen-plus / qwen-turbo 模型
#
DASHSCOPE_API_KEY=your_api_key_here

# Flask 服务端口 (默认5000)
PORT=5000

# SQLite 数据库文件路径
DATABASE_PATH=hospital.db

# 是否启用 Flask Debug 模式 (默认True)
FLASK_DEBUG=True
